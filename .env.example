# CareMetric AI — environment configuration
# Copy to `.env` and fill in real values. `.env` itself is gitignored.
# Only DATABASE_URL is required to boot in development; production additionally
# requires JWT_SECRET (the server refuses to start without it).

# ─── Database (required) ──────────────────────────────────────────────────────
# PostgreSQL connection string used by Drizzle / the pg pool.
DATABASE_URL=postgresql://user:password@host:5432/caremetric
# Max connections in the pool (default 30).
DB_POOL_MAX=30

# ─── Runtime ──────────────────────────────────────────────────────────────────
# "production" or "development". Affects cookie security, CORS enforcement,
# admin-seed behavior, and whether internal error details are returned.
NODE_ENV=development
# API server port (PORT takes precedence, then API_PORT, default 3001).
PORT=3001

# ─── Auth (JWT_SECRET required in production) ─────────────────────────────────
# Secret used to sign session JWTs. REQUIRED in production — the server throws
# on startup if unset. In development an ephemeral random secret is generated
# (sessions drop on restart). Use a long random string.
JWT_SECRET=

# First-admin seed. In production the admin is only seeded if ADMIN_PASSWORD is
# set; in development a non-secret placeholder password is used if unset.
ADMIN_EMAIL=admin@caremetric.local
ADMIN_PASSWORD=
ADMIN_FULL_NAME=CareMetric Admin

# ─── CORS (production) ────────────────────────────────────────────────────────
# Comma-separated list of allowed browser origins, enforced only in production.
# Leave unset for a same-origin deployment (the SPA is served by the API).
ALLOWED_ORIGINS=

# ─── Anthropic / Claude (required for AI features) ────────────────────────────
ANTHROPIC_API_KEY=
# Optional model overrides — roll out model upgrades without a code change.
CLAUDE_MODEL_SONNET=claude-sonnet-4-6
CLAUDE_MODEL_HAIKU=claude-haiku-4-5-20251001
CLAUDE_MODEL_OPUS=claude-opus-4-7

# ─── Maintenance / scheduled imports ──────────────────────────────────────────
# Shared secret for the unauthenticated maintenance endpoints under
# /api/maintenance/* (runScheduledImports, autoRetryFailedImports,
# autoResumePausedImports, cancelStalledImports). Point an external scheduler
# (e.g. a Replit Scheduled Deployment or system cron) at
#   POST /api/maintenance/runScheduledImports
# with header `x-maintenance-token: <this value>` every ~10 minutes. If unset,
# these endpoints are reachable only by an authenticated admin (no cron access).
MAINTENANCE_TOKEN=

# ─── Email / SendGrid (required to send email) ────────────────────────────────
SENDGRID_API_KEY=
# Default + primary allowed sender address.
SENDGRID_FROM_EMAIL=noreply@caremetric.com
# Optional extra comma-separated sender addresses the /email/send endpoint may
# use. A caller-supplied "from" is honored only if it is on this allowlist;
# otherwise it falls back to SENDGRID_FROM_EMAIL (prevents open relay/spoofing).
ALLOWED_FROM_EMAILS=
